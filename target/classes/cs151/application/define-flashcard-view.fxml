<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20" stylesheets="@style.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="cs151.application.DefineFlashcardController"
      styleClass="page">

    <VBox alignment="CENTER_LEFT" spacing="12" styleClass="form-card" maxWidth="500">
        <padding>
            <Insets top="24" right="24" bottom="24" left="24"/>
        </padding>

        <Label text="Define Flashcard" styleClass="title"/>

        <Label text="Select Deck" styleClass="field-label"/>
        <ComboBox fx:id="deckComboBox" prefWidth="440"/>

        <Label text="Question" styleClass="field-label"/>
        <TextField fx:id="questionField" promptText="Enter question" prefWidth="440"/>

        <Label text="Answer" styleClass="field-label"/>
        <TextField fx:id="answerField" promptText="Enter answer" prefWidth="440"/>

        <Label fx:id="statusLabel" text="" wrapText="true" styleClass="status-label"/>

        <VBox spacing="10">
            <Button text="Save Flashcard" onAction="#handleSaveFlashcard" styleClass="primary-button"/>
            <Button text="Back" onAction="#handleBackHome" styleClass="secondary-button"/>
        </VBox>
    </VBox>

</VBox>