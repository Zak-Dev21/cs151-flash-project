<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="cs151.application.DeckListController">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="All Decks" />

    <TableView fx:id="deckTable" prefHeight="400" prefWidth="700">
        <columns>
            <TableColumn fx:id="nameColumn" prefWidth="180" text="Deck Name" />
            <TableColumn fx:id="descriptionColumn" prefWidth="350" text="Description" />
            <TableColumn fx:id="colorColumn" prefWidth="150" text="Color" />
        </columns>
    </TableView>

    <Label fx:id="statusLabel" text="" />

    <Button text="Back" onAction="#handleBackHome" />
</VBox>